<!-- app/views/users/show.html.erb -->
<div class="user-profile-container">
  <div class="profile-header">
    <div class="photo-frame">
      <!% if @user.photo.present? %>
        <%= image_tag @user.photo, class: "profile-photo" %>
      <!% else %>
        <!%= image_tag "default-profile.jpg", class: "profile-photo" %>
      <!% end %>
    </div>
    
    <div class="user-info">
      <h1><%= @user.name %></h1>
      <div class="basic-info">
        <span class="age"><%= @user.age %> years old</span>
        <span class="gender"><%= @user.gender %></span>
      </div>
      <div class="location">
        <i class="fas fa-map-marker-alt"></i>
        <%= "#{@user.city}, #{@user.country}" %>
      </div>
      <div class="looking-for">
        Looking for: <%= @user.looking_for %>
      </div>
    </div>
  </div>

   <div class="interests-section">
    <h2>Interests</h2>
    <div class="interests-grid">
      <% @user.interests.each do |interest| %>
        <div class="interest-card">
          <h3><%= interest.interest %></h3>
          <p><%= interest.description %></p> 
          <div class="looking-for">
             Passion Level: <%= interest.interest_level %>
          </div>
         </div>
      <% end %>
    </div>
  </div>
</div>

  <div>
    <h2> </h2>
    <%= link_to "Add New Interest", new_interest_path(@user), class: "btn btn-primary" %>
  </div>

<!%= link_to 'Edit Profile', edit_user_path(@user), class: 'edit-button' if current_user == @user %>

